POSTGRES_USER=golfops
POSTGRES_PASSWORD=replace-with-a-long-random-password
CLOUDFLARE_TUNNEL_TOKEN=replace-with-cloudflare-token

# Ollama — runs natively on Mac, reachable from Docker via host.docker.internal
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_EMBEDDING_MODEL=embeddinggemma:300m

# Gmail OAuth2 — create credentials at console.cloud.google.com
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GMAIL_CALLBACK_URL=https://golf.kjarisk.com/api/auth/gmail/callback

# Bookings — synced from a Google Calendar that Acuity feeds (Acuity → Sync with
# other Calendars). Use a DEDICATED calendar (not your primary) so every event is a
# lesson. golfops reads it read-only via the Gmail OAuth above (calendar.readonly scope).
# Set this to that calendar's ID (e.g. abcd1234@group.calendar.google.com).
GOOGLE_BOOKINGS_CALENDAR_ID=replace-with-dedicated-calendar-id
# Optional: default activity type when an event title has no "Type - Client" split
GOOGLE_BOOKINGS_DEFAULT_TYPE=Lesson
# Optional: how often (ms) to poll the calendar for new/changed bookings (default 5 min)
BOOKINGS_SYNC_INTERVAL_MS=300000
